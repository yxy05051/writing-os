{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Writing OS Plan",
  "type": "object",
  "required": ["project", "articles"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "audience": { "type": "string" },
        "outcome": { "type": "string" },
        "tone": { "type": "string" }
      }
    },
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["num", "title", "goal"],
        "properties": {
          "num": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "goal": { "type": "string" },
          "audience": { "type": "string" },
          "reader_level": { "type": "string" },
          "tree_position": { "type": "object" },
          "key_points": { "type": "array", "items": { "type": "string" } },
          "constraints": { "type": "array", "items": { "type": "string" } },
          "next_hook": { "type": "string" },
          "outline": { "type": "string" }
        }
      }
    }
  }
}
